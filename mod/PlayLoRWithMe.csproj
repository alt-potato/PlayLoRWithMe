<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import
    Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props"
    Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')"
  />
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{75466C30-4F8C-4E93-B582-594B5C22671F}</ProjectGuid>
    <OutputType>Library</OutputType>
    <AppDesignerFolder>Properties</AppDesignerFolder>
    <RootNamespace>PlayLoRWithMe</RootNamespace>
    <AssemblyName>PlayLoRWithMe</AssemblyName>
    <TargetFrameworkVersion>v4.8</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <Deterministic>true</Deterministic>
  </PropertyGroup>

  <!--
    Locate the game's Managed/ DLL directory.

    Resolution order:
      1. The LOR_MANAGED_DIR environment variable, if set. Use this on machines
         where Steam isn't installed in the default Program Files (x86) path
         (e.g. a different drive, a Linux Proton install, or CI).
      2. The default Steam install path, mirroring what the Steam client
         creates on a stock Windows install.

    Override locally with:
      set LOR_MANAGED_DIR=D:\Games\Library Of Ruina\LibraryOfRuina_Data\Managed

    Both ItemGroup HintPaths below and the AfterBuild Copy step read $(LorManagedDir).
  -->
  <PropertyGroup>
    <LorManagedDir Condition=" '$(LOR_MANAGED_DIR)' != '' ">$(LOR_MANAGED_DIR)</LorManagedDir>
    <LorManagedDir Condition=" '$(LorManagedDir)' == '' ">..\..\..\..\..\Program Files (x86)\Steam\steamapps\common\Library Of Ruina\LibraryOfRuina_Data\Managed</LorManagedDir>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="0Harmony">
      <HintPath>packages\Lib.Harmony.2.3.3\lib\net48\0Harmony.dll</HintPath>
    </Reference>
    <Reference Include="Assembly-CSharp">
      <HintPath>$(LorManagedDir)\Assembly-CSharp.dll</HintPath>
    </Reference>
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <Reference Include="System.Xml.Linq" />
    <Reference Include="System.Data.DataSetExtensions" />
    <Reference Include="Microsoft.CSharp" />
    <Reference Include="System.Data" />
    <Reference Include="System.Net.Http" />
    <Reference Include="System.Xml" />
    <Reference Include="UnityEngine.ImageConversionModule">
      <HintPath>$(LorManagedDir)\UnityEngine.ImageConversionModule.dll</HintPath>
    </Reference>
    <Reference Include="UnityEngine.CoreModule">
      <HintPath>$(LorManagedDir)\UnityEngine.CoreModule.dll</HintPath>
    </Reference>
    <Reference Include="Unity.TextMeshPro">
      <HintPath>$(LorManagedDir)\Unity.TextMeshPro.dll</HintPath>
    </Reference>
    <Reference Include="UnityEngine.UI">
      <HintPath>$(LorManagedDir)\UnityEngine.UI.dll</HintPath>
    </Reference>
  </ItemGroup>
  <ItemGroup>
    <Compile Include="ActionInjector.cs" />
    <Compile Include="AppearanceCache.cs" />
    <Compile Include="GiftCache.cs" />
    <Compile Include="IconCache.cs" />
    <Compile Include="JsonReader.cs" />
    <Compile Include="JsonWriter.cs" />
    <Compile Include="MultiDeckLabels.cs" />
    <Compile Include="MultiDeckLabelHook.cs" />
    <Compile Include="GameStateSerializer.cs" />
    <Compile Include="Initializer.cs" />
    <Compile Include="Properties\AssemblyInfo.cs" />
    <Compile Include="Server.cs" />
    <Compile Include="StateBroadcaster.cs" />
    <Compile Include="DeltaEngine.cs" />
    <Compile Include="SessionManager.cs" />
    <Compile Include="WebSocketClient.cs" />
    <Compile Include="WebSocketCodec.cs" />
  </ItemGroup>
  <ItemGroup>
    <None Include="packages.config" />
  </ItemGroup>
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />

  <!--
    AfterBuild: build the Vue frontend, then assemble a deployable mod folder
    inside $(OutputPath). Result layout mirrors what LoR expects:
      bin\Debug\PlayLoRWithMe\
        StageModInfo.xml
        Data\...
        Resource\...
        wwwroot\...     <- copied directly from frontend\.output\public\
        Assemblies\
          PlayLoRWithMe.dll
          PlayLoRWithMe.pdb   (Debug only)
  -->
  <PropertyGroup>
    <FrontendDir>$(MSBuildProjectDirectory)\..\frontend</FrontendDir>
  </PropertyGroup>

  <!--
    NpmInstall: skipped on incremental builds when node_modules is already in
    sync with package-lock.json. The Inputs/Outputs gate uses MSBuild's
    timestamp comparison: if `node_modules\.package-lock.json` (the marker npm
    writes after a successful install) is newer than `package-lock.json`, the
    target is up-to-date and `npm install` doesn't run. The install command
    uses prefer-offline (reuse local cache) and no-audit / no-fund (strip
    output we don't act on); see the Exec Command attribute below for the
    flags.
  -->
  <Target
    Name="NpmInstall"
    Inputs="$(FrontendDir)\package.json;$(FrontendDir)\package-lock.json"
    Outputs="$(FrontendDir)\node_modules\.package-lock.json"
    Condition="Exists('$(FrontendDir)\package.json')"
  >
    <Exec
      Command="npm install --prefer-offline --no-audit --no-fund"
      WorkingDirectory="$(FrontendDir)"
    />
  </Target>

  <Target Name="AfterBuild" DependsOnTargets="NpmInstall">
    <!-- Build the Vue frontend if it has been scaffolded. `npm run generate`
         always runs because Nuxt's incremental build is faster than tracking
         every frontend source file from MSBuild; the Copy step below uses
         SkipUnchangedFiles to keep deploy-side I/O minimal when nothing
         actually changed in the static output. -->
    <Exec
      Command="npm run generate --logLevel=silent"
      WorkingDirectory="$(FrontendDir)"
      Condition="Exists('$(FrontendDir)\package.json')"
    />

    <!-- Copy ModData contents (everything except wwwroot) into the output root.
         %(RecursiveDir) is relative to the ModData\ wildcard base, so the
         ModData\ prefix is automatically stripped. -->
    <ItemGroup>
      <ModDataFiles Include="ModData\**\*" />
    </ItemGroup>
    <Copy
      SourceFiles="@(ModDataFiles)"
      DestinationFiles="@(ModDataFiles->'$(OutputPath)PlayLoRWithMe\%(RecursiveDir)%(Filename)%(Extension)')"
      SkipUnchangedFiles="true"
    />

    <!-- Copy the Vite build output directly into wwwroot\ in the output.
         %(RecursiveDir) is relative to the frontend\.output\public\ wildcard base. -->
    <ItemGroup>
      <FrontendDistFiles
        Include="$(FrontendDir)\.output\public\**\*"
        Condition="Exists('$(FrontendDir)\.output\public')"
      />
    </ItemGroup>
    <Copy
      SourceFiles="@(FrontendDistFiles)"
      DestinationFiles="@(FrontendDistFiles->'$(OutputPath)PlayLoRWithMe\wwwroot\%(RecursiveDir)%(Filename)%(Extension)')"
      SkipUnchangedFiles="true"
    />

    <!-- Place the compiled DLL (and PDB if present) in Assemblies\ -->
    <Copy
      SourceFiles="$(OutputPath)$(AssemblyName).dll"
      DestinationFolder="$(OutputPath)PlayLoRWithMe\Assemblies\"
    />
    <Copy
      SourceFiles="$(OutputPath)$(AssemblyName).pdb"
      DestinationFolder="$(OutputPath)PlayLoRWithMe\Assemblies\"
      Condition="Exists('$(OutputPath)$(AssemblyName).pdb')"
    />

    <!-- Copy third-party dependencies into Assemblies\ -->
    <Copy
      SourceFiles="packages\Lib.Harmony.2.3.3\lib\net48\0Harmony.dll"
      DestinationFolder="$(OutputPath)PlayLoRWithMe\Assemblies\"
      SkipUnchangedFiles="true"
    />
  </Target>
</Project>
