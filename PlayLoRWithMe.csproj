  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />

  <!--
    AfterBuild: assemble a deployable mod folder inside $(OutputPath).
    Result layout mirrors what LoR expects:
      bin\Debug\PlayLoRWithMe\
        StageModInfo.xml
        Data\...
        Resource\...
        wwwroot\...
        Assemblies\
          PlayLoRWithMe.dll
          PlayLoRWithMe.pdb   (Debug only)
  -->
  <Target Name="AfterBuild">
    <!-- Collect everything inside ModData\ -->
    <ItemGroup>
      <ModDataFiles Include="ModData\**\*" />
    </ItemGroup>

    <!-- Copy ModData contents into the output root, preserving sub-paths.
         %(RecursiveDir) is relative to the ModData\ wildcard base, so the
         ModData\ prefix is automatically stripped. -->
    <Copy SourceFiles="@(ModDataFiles)"
          DestinationFiles="@(ModDataFiles->'$(OutputPath)PlayLoRWithMe\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />

    <!-- Place the compiled DLL (and PDB if present) in Assemblies\ -->
    <Copy SourceFiles="$(OutputPath)$(AssemblyName).dll"
          DestinationFolder="$(OutputPath)PlayLoRWithMe\Assemblies\" />
    <Copy SourceFiles="$(OutputPath)$(AssemblyName).pdb"
          DestinationFolder="$(OutputPath)PlayLoRWithMe\Assemblies\"
          Condition="Exists('$(OutputPath)$(AssemblyName).pdb')" />
  </Target>
</Project>